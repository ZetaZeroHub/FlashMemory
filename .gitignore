# ====================
# FlashMemory .gitignore
# ====================

# --- Go ---
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
vendor/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/
*.whl
.venv/
.env/

# --- IDE ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# --- FlashMemory specific ---
.gitgo/
*.gitgo.tar.gz
flashmemory.gitgo.tar.gz

# --- AI tools ---
.agents/
!.agents/skills/
.agents/skills/*
!.agents/skills/flashmemory-core/
!.agents/skills/flashmemory-index/
!.agents/skills/flashmemory-query/
.claude/
.trae/
.githave/
docs/ai.log
skills-lock.json

# --- Build artifacts ---
pip-package/dist/
pip-package/build/
pip-package/*.egg-info/

# --- Virtual environments (per-directory) ---
cmd/app/.env/
cmd/main/FAISSService/.env/

# --- Temp/lock files ---
*.temp
*.lock

# Build binaries
fm
fm_http
fm_core
fm_linux
fm_http_linux

